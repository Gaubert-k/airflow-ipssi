# Utilisateur Linux hôte (évite les fichiers créés en root dans dags/logs/plugins/config)
AIRFLOW_UID=1000

# Clé de chiffrement des connexions Airflow (générée une fois, à conserver)
FERNET_KEY=

# Image Docker (Airflow 3.2.1 — doc officielle)
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.1

# Exercice 3 — publication Kafka depuis les workers Airflow
_PIP_ADDITIONAL_REQUIREMENTS=kafka-python
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_WEATHER_ALERTS_TOPIC=weather_alerts
